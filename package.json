{
  "name": "shakeeb-task2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "dev:frontend": "npm --prefix src/frontend run dev",
    "dev:backend": "npm --prefix src/backend run dev",
    "dev:all": "start \"Task2 Backend\" cmd /k \"cd /d src\\backend && npm run dev\" && start \"Task2 Frontend\" cmd /k \"cd /d src\\frontend && npm run dev\"",
    "build": "npm --prefix src/frontend run build",
    "lint": "eslint .",
    "preview": "npm --prefix src/frontend run preview"
  },
  "dependencies": {
    "mongodb": "^7.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
